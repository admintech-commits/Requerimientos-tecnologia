# ──────────────────────────────────────────────────────
# Variables de entorno — requerimientos-tecnologia
# Copiar como .env y completar los valores reales.
# NUNCA versionar el .env con valores reales.
# ──────────────────────────────────────────────────────

# ── Frontend (Vite, solo en desarrollo local) ──
# En producción el frontend es un build estático; esta variable no se usa.
VITE_API_URL=http://localhost:3000/api

# ── Backend (Docker / producción) ──
NODE_ENV=production
PORT=3000

# Ruta SQLite dentro del contenedor
DB_PATH=/app/data/requerimientos.db

# JWT — generar con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO

# Origen CORS (dominio real o * para acceso abierto mientras no haya dominio)
CORS_ORIGIN=*
