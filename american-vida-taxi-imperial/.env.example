# ──────────────────────────────────────────────────────
# Variables de entorno — requerimientos-tecnologia
# Copiar como .env y completar los valores reales.
# NUNCA versionar el .env con valores reales.
# ──────────────────────────────────────────────────────

# ── Frontend (Vite, solo en desarrollo local) ──
# En producción el frontend es un build estático; esta variable no se usa.
VITE_API_URL=http://localhost:3000/api

# ── Backend (Docker / producción) ──
NODE_ENV=production
PORT=3000

# Ruta SQLite dentro del contenedor
DB_PATH=/app/data/requerimientos.db

# JWT — generar con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO

# Origen CORS (dominio real o * para acceso abierto mientras no haya dominio)
CORS_ORIGIN=*

# ── Correo (Resend) ──
# Necesario para enviar notificaciones cuando se asigna un requerimiento.
# Si se omite, el sistema funciona igual pero sin enviar correos.
#
# Pasos para obtener la API Key:
#   1. Crea cuenta en resend.com
#   2. Ve a API Keys → Create API Key
#   3. Copia la clave (empieza con re_...)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Remitente que verán los destinatarios.
# Con la cuenta gratuita de Resend puedes usar: onboarding@resend.dev
# Si verificas tu propio dominio en Resend, usa: Requerimientos <noreply@tudominio.com>
EMAIL_FROM=Requerimientos AmVi <onboarding@resend.dev>

# URL pública de la app (se incluye en el enlace del correo)
APP_URL=https://tu-dominio.com
